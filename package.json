{
  "name": "dice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "check": "npm run check --workspaces --if-present",
    "check:shared": "npm run check --workspace=shared",
    "check:server": "npm run check --workspace=server",
    "check:client": "npm run check --workspace=client",
    "test": "vitest run",
    "test:shared": "vitest run shared/src",
    "test:server": "vitest run server/src server/test",
    "test:client": "vitest run client/src",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "npm run lint && npm run check && npm test",
    "sync:cursor": "node scripts/sync-cursor-commands.mjs",
    "prepare": "git config core.hooksPath .githooks",
    "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
    "start": "NODE_ENV=production npm run start --workspace=server"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
