{
  "name": "@dice/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --packages=external --alias:@dice/shared=../shared/src/index.ts --outfile=dist/index.js",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dice/shared": "^0.1.0",
    "express": "^5.2.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4"
  }
}
